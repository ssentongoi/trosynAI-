<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Trosyn AI – Private, Offline AI for Businesses</title>
<meta name="description" content="Trosyn AI helps businesses run private AI locally. Starting in constrained markets, it delivers offline, compliant workflow automation without cloud dependency."/>
<meta name="theme-color" content="#006054"/>
<link rel="icon" href="assets/images/favicon.svg" type="image/svg+xml"/>
<link rel="shortcut icon" href="assets/images/favicon.svg" type="image/svg+xml"/>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,900;1,300;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root {
  --green:   #006054;
  --navy:    #14283C;
  --coral:   #DC503C;
  --gold:    #F0B464;
  --teal-lt: #DCF0F0;
  --teal-md: #3C6464;
  --cream:   #F8F4EC;
  --soft-white: #f5f6f4;
  --white:   #F0F0F0;
  --pure:    #FFFFFF;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--green);color:var(--white);font-family:'DM Sans',sans-serif;font-weight:400;line-height:1.7;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:0.35;}
.topo{position:fixed;inset:0;pointer-events:none;z-index:0;opacity:0.05;background-image:repeating-radial-gradient(ellipse at 20% 50%,transparent 0,transparent 40px,#DCF0F0 41px,transparent 42px),repeating-radial-gradient(ellipse at 80% 20%,transparent 0,transparent 60px,#DCF0F0 61px,transparent 62px);}
.container{position:relative;z-index:1;max-width:960px;margin:0 auto;padding:0 28px;}
section{padding:88px 0;}
.divider{height:1px;background:linear-gradient(90deg,transparent,rgba(220,240,240,0.18),transparent);}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(0,96,84,0.93);backdrop-filter:blur(14px);border-bottom:1px solid rgba(220,240,240,0.08);padding:0 28px;}
.nav-inner{max-width:960px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:68px;}
.nav-logo{display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:var(--pure);white-space:nowrap;}
.nav-logo-icon{height:36px;width:auto;flex-shrink:0;display:block;}
.nav-logo-wordmark{display:inline-flex;align-items:baseline;gap:3px;font-family:'DM Sans',sans-serif;font-size:1.45rem;font-weight:600;letter-spacing:-0.055em;line-height:1;color:var(--pure);}
.nav-logo-ai{font-weight:500;letter-spacing:-0.065em;opacity:0.94;}
.nav-links{display:flex;align-items:center;gap:8px;list-style:none;}
.nav-links a{color:var(--white);text-decoration:none;font-size:0.84rem;font-weight:500;padding:7px 16px;border-radius:4px;opacity:0.75;transition:opacity 0.2s,background 0.2s;}
.nav-links a:hover{opacity:1;background:rgba(220,240,240,0.08);}
.nav-links a.active{opacity:1;color:var(--pure);}
.nav-cta{background:#e05a3a!important;color:#ffffff!important;opacity:1!important;font-weight:700!important;border-radius:6px!important;padding:10px 22px!important;}
.nav-cta:hover{background:#c44030!important;}
@media(max-width:860px){
  nav{padding:0 16px;}
  .nav-inner{height:auto;min-height:68px;padding:10px 0;align-items:flex-start;flex-direction:column;gap:10px;}
  .nav-links{width:100%;overflow-x:auto;white-space:nowrap;gap:6px;padding-bottom:2px;}
  .nav-links a{display:inline-flex;align-items:center;min-height:44px;padding:10px 14px;font-size:0.82rem;}
  .nav-cta{padding:10px 18px!important;}
}

/* HERO */
.hero{padding:116px 0 100px;}
.hero .container{max-width:1120px;}
.hero-copy{max-width:760px;}
.hero-badge{display:inline-flex;align-items:center;background:rgba(240,180,100,0.12);border:1px solid rgba(240,180,100,0.25);color:var(--gold);font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:6px 18px;border-radius:100px;margin-bottom:34px;}
.hero h1{font-family:'Fraunces',serif;font-weight:900;font-size:clamp(3.6rem,8vw,6.35rem);line-height:0.92;letter-spacing:-0.05em;color:var(--pure);margin-bottom:28px;max-width:8.2ch;text-wrap:balance;}
.hero-line,.hero-line-accent{display:block;}
.hero-line-accent{font-style:italic;color:var(--gold);}
.hero-sub{font-size:clamp(1rem,2vw,1.2rem);color:var(--teal-lt);max-width:680px;margin-bottom:44px;font-weight:300;line-height:1.72;}
.hero-actions{display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--coral);color:var(--pure);padding:15px 30px;border-radius:4px;font-weight:600;font-size:0.9rem;text-decoration:none;letter-spacing:0.02em;transition:background 0.2s,transform 0.2s;}
.btn-primary:hover{background:#c44030;transform:translateY(-2px);}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;color:var(--teal-lt);font-size:0.88rem;font-weight:500;text-decoration:none;padding:15px 4px;border-bottom:1px solid rgba(220,240,240,0.2);transition:border-color 0.2s,color 0.2s;}
.btn-ghost:hover{color:var(--pure);border-color:rgba(220,240,240,0.5);}
.hero-visual{margin-top:76px;background:rgba(20,40,60,0.4);border:1px solid rgba(220,240,240,0.08);border-radius:12px;padding:32px;display:grid;grid-template-columns:repeat(3,1fr);gap:1px;overflow:hidden;}
.hero-stat{padding:24px 20px;text-align:center;background:rgba(0,0,0,0.1);transition:background 0.35s,transform 0.35s;}
.hero-stat.is-active{background:rgba(0,0,0,0.18);transform:translateY(-2px);}
.hero-stat-num{font-family:'Fraunces',serif;font-size:2.2rem;font-weight:900;color:var(--gold);line-height:1;font-variant-numeric:tabular-nums lining-nums;}
.hero-stat-label{font-size:0.77rem;color:var(--teal-lt);margin-top:6px;opacity:0.8;line-height:1.4;}

/* SECTION LABELS */
.section-label{font-size:0.72rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--coral);margin-bottom:16px;}
.section-title{font-family:'Fraunces',serif;font-weight:700;font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.15;letter-spacing:-0.02em;color:var(--pure);margin-bottom:20px;}
.section-body{font-size:0.95rem;color:var(--teal-lt);max-width:600px;line-height:1.8;opacity:0.9;}

/* PROBLEM */
.problem-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2px;margin-top:48px;border-radius:8px;overflow:hidden;background:rgba(220,240,240,0.06);}
.problem-card{background:rgba(20,40,60,0.55);padding:36px 28px;position:relative;}
.problem-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--coral);}
.problem-icon{font-size:1.6rem;margin-bottom:16px;}
.problem-title{font-weight:700;font-size:1rem;color:var(--pure);margin-bottom:10px;}
.problem-text{font-size:0.85rem;color:var(--teal-lt);line-height:1.7;opacity:0.85;}

/* SOLUTION */
.solution-layout{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px;align-items:center;}
.solution-left{}
.solution-features{display:flex;flex-direction:column;gap:0;}
.feature-row{display:flex;gap:20px;padding:22px 0;border-bottom:1px solid rgba(220,240,240,0.07);align-items:flex-start;}
.feature-row:first-child{padding-top:0;}
.feature-row:last-child{border-bottom:none;padding-bottom:0;}
.feature-icon{width:40px;height:40px;background:rgba(240,180,100,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.feature-name{font-weight:600;font-size:0.92rem;color:var(--pure);margin-bottom:4px;}
.feature-desc{font-size:0.82rem;color:var(--teal-lt);line-height:1.6;opacity:0.8;}
.solution-callout{background:rgba(0,0,0,0.2);border-radius:10px;padding:32px;}
.solution-callout-title{font-family:'Fraunces',serif;font-size:1.3rem;font-weight:700;color:var(--pure);margin-bottom:20px;line-height:1.3;}
.solution-callout-title em{color:var(--gold);font-style:italic;}
.arch-flow{display:flex;flex-direction:column;gap:8px;margin-bottom:24px;}
.arch-node{background:rgba(20,40,60,0.6);border:1px solid rgba(220,240,240,0.1);border-radius:6px;padding:14px 18px;font-size:0.82rem;display:flex;align-items:center;gap:12px;}
.arch-node-icon{width:28px;height:28px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:0.9rem;flex-shrink:0;}
.arch-node-icon.gold{background:rgba(240,180,100,0.15);}
.arch-node-icon.coral{background:rgba(220,80,60,0.15);}
.arch-node-icon.teal{background:rgba(60,100,100,0.3);}
.arch-node-label{color:var(--white);font-weight:500;}
.arch-node-desc{color:var(--teal-lt);opacity:0.65;font-size:0.78rem;}
.arch-arrow{text-align:center;color:var(--teal-md);font-size:0.75rem;padding:2px 0;}
.arch-note{font-size:0.75rem;color:var(--teal-md);font-style:italic;text-align:center;padding-top:16px;border-top:1px solid rgba(220,240,240,0.07);}

/* FEATURES GRID */
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:48px;}
.feat-card{background:rgba(20,40,60,0.4);border:1px solid rgba(220,240,240,0.07);border-radius:8px;padding:28px 24px;transition:border-color 0.2s,background 0.2s;}
.feat-card:hover{border-color:rgba(240,180,100,0.2);background:rgba(20,40,60,0.7);}
.feat-card-icon{font-size:1.4rem;margin-bottom:14px;}
.feat-card-name{font-weight:700;font-size:0.92rem;color:var(--pure);margin-bottom:8px;}
.feat-card-desc{font-size:0.82rem;color:var(--teal-lt);line-height:1.6;opacity:0.8;}

/* USE CASES */
.use-cases{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;margin-top:48px;}
.use-case{background:rgba(20,40,60,0.45);border:1px solid rgba(220,240,240,0.07);border-radius:6px;padding:24px 20px;position:relative;overflow:hidden;}
.use-case::after{content:'';position:absolute;bottom:-24px;right:-16px;width:60px;height:60px;background:radial-gradient(circle,rgba(240,180,100,0.06) 0%,transparent 70%);border-radius:50%;}
.use-case-dept{font-size:0.68rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.use-case-title{font-weight:600;font-size:0.9rem;color:var(--pure);margin-bottom:10px;}
.use-case-list{list-style:none;display:flex;flex-direction:column;gap:5px;}
.use-case-list li{font-size:0.78rem;color:var(--teal-lt);opacity:0.8;padding-left:14px;position:relative;line-height:1.4;}
.use-case-list li::before{content:'→';position:absolute;left:0;color:var(--teal-md);font-size:0.7rem;}

/* FAQ */
.faq-shell{padding-top:6px;}
.faq-intro{max-width:720px;margin-bottom:42px;}
.faq-intro .section-title{max-width:11ch;margin-bottom:18px;}
.faq-intro .section-body{max-width:640px;font-size:1rem;}
.faq-list{border-top:1px solid rgba(220,240,240,0.1);}
.faq-item{border-bottom:1px solid rgba(220,240,240,0.1);transition:border-color 0.35s ease;}
.faq-item.is-open{border-bottom-color:rgba(220,80,60,0.22);}
.faq-question{width:100%;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:24px;align-items:center;background:transparent;border:none;color:inherit;padding:28px 0;text-align:left;cursor:pointer;font:inherit;}
.faq-question-text{font-size:1.05rem;font-weight:700;line-height:1.4;color:var(--pure);padding-right:12px;}
.faq-toggle{width:56px;height:56px;border-radius:50%;border:2px solid rgba(220,240,240,0.2);display:inline-flex;align-items:center;justify-content:center;position:relative;transition:background 0.35s ease,border-color 0.35s ease,transform 0.35s ease,box-shadow 0.35s ease;}
.faq-toggle::before,.faq-toggle::after{content:'';position:absolute;width:18px;height:2px;border-radius:999px;background:var(--teal-lt);transition:transform 0.35s ease,background 0.35s ease,opacity 0.35s ease;}
.faq-toggle::after{transform:rotate(90deg);}
.faq-question:hover .faq-toggle{border-color:rgba(240,180,100,0.32);transform:translateY(-1px);}
.faq-item.is-open .faq-toggle{background:var(--coral);border-color:rgba(240,180,100,0.42);box-shadow:0 12px 28px rgba(220,80,60,0.2);}
.faq-item.is-open .faq-toggle::before,.faq-item.is-open .faq-toggle::after{background:var(--pure);}
.faq-item.is-open .faq-toggle::before{transform:rotate(45deg);}
.faq-item.is-open .faq-toggle::after{transform:rotate(-45deg);}
.faq-answer-wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows 0.45s cubic-bezier(0.22,1,0.36,1);}
.faq-item.is-open .faq-answer-wrap{grid-template-rows:1fr;}
.faq-answer{overflow:hidden;}
.faq-answer-inner{padding:0 92px 34px 0;max-width:1100px;}
.faq-answer-inner p{font-size:0.95rem;color:var(--teal-lt);line-height:1.9;opacity:0.92;margin-bottom:18px;}
.faq-answer-inner p:last-child{margin-bottom:0;}

/* CTA */
.cta-section{background:rgba(20,40,60,0.4);border:1px solid rgba(220,240,240,0.07);border-radius:12px;padding:64px 48px;text-align:center;position:relative;overflow:hidden;}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(220,80,60,0.06) 0%,transparent 70%);}
.cta-title{font-family:'Fraunces',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:900;color:var(--pure);letter-spacing:-0.03em;margin-bottom:16px;position:relative;}
.cta-title em{color:var(--gold);font-style:italic;}
.cta-body{font-size:0.95rem;color:var(--teal-lt);opacity:0.8;margin-bottom:36px;max-width:420px;margin-left:auto;margin-right:auto;position:relative;}
.cta-button{display:inline-flex;align-items:center;gap:10px;background:var(--coral);color:var(--pure);padding:14px 28px;border-radius:4px;font-weight:600;font-size:0.9rem;text-decoration:none;letter-spacing:0.02em;transition:background 0.2s,transform 0.2s;position:relative;}
.cta-button:hover{background:#c44030;transform:translateY(-2px);}

/* HOMEPAGE COLORWAY POLISH */
.divider{display:none;}

#problem,#solution,#features{
  background:var(--soft-white);
}

#faq{
  background:var(--cream);
}

#problem .section-title,
#solution .section-title,
#features .section-title,
#faq .section-title{
  color:var(--navy);
}

#problem .section-body,
#solution .section-body,
#features .section-body,
#faq .section-body{
  color:#4d6072;
}

#problem .section-label,
#solution .section-label,
#features .section-label,
#faq .section-label{
  color:var(--green);
}

#problem .problem-grid{
  background:#e4eceb;
}

#problem .problem-card{
  background:#f2f6f4;
}

#problem .problem-title{
  color:var(--navy);
}

#problem .problem-text{
  color:#566879;
}

#solution .feature-row{
  border-bottom:1px solid #dbe5e3;
}

#solution .feature-name{
  color:var(--navy);
}

#solution .feature-desc{
  color:#566879;
}

#solution .solution-callout{
  background:linear-gradient(160deg,#0b5b4e 0%,#08473f 100%);
  border:1px solid rgba(0,96,84,0.28);
}

#solution .arch-note{
  color:#a7c8c2;
}

#features .use-case{
  background:#f8faf8;
  border:1px solid rgba(0,96,84,0.22);
}

#features .use-case-title{
  color:var(--navy);
}

#features .use-case-list li{
  color:#506375;
}

#features .use-case-list li::before{
  color:#2d7367;
}

#faq .faq-list{
  border-top:1px solid rgba(20,40,60,0.14);
}

#faq .faq-item{
  border-bottom:1px solid rgba(20,40,60,0.14);
}

#faq .faq-question-text{
  color:var(--navy);
}

#faq .faq-toggle{
  border-color:rgba(20,40,60,0.2);
}

#faq .faq-toggle::before,
#faq .faq-toggle::after{
  background:#496174;
}

#faq .faq-answer-inner p{
  color:#4f6275;
}

.cta-section{
  background:linear-gradient(150deg,#2f725d 0%,#245f4f 62%,#1d4f43 100%);
  border:1px solid rgba(220,240,240,0.16);
  box-shadow:0 24px 46px rgba(7,35,36,0.26);
}

.cta-section::before{
  background:radial-gradient(ellipse at 50% 0%,rgba(240,180,100,0.18) 0%,transparent 72%);
}

.cta-body{
  color:rgba(255,255,255,0.82);
}

.cta-signoff{
  margin-top:16px;
  font-size:0.8rem;
  color:rgba(220,240,240,0.66);
}

.reveal{opacity:0;transform:translate3d(0,var(--reveal-distance,24px),0);transition:opacity 0.72s cubic-bezier(0.22,1,0.36,1),transform 0.72s cubic-bezier(0.22,1,0.36,1);transition-delay:var(--reveal-delay,0ms);will-change:opacity,transform;}
.reveal-left{transform:translate3d(calc(var(--reveal-distance,24px) * -1),0,0);}
.reveal-right{transform:translate3d(var(--reveal-distance,24px),0,0);}
.reveal.is-visible{opacity:1;transform:translate3d(0,0,0);}

footer{
  background:linear-gradient(145deg,#0d3f34 0%,#0a3129 100%);
  border-top:1px solid rgba(220,240,240,0.14);
  padding:56px 0 28px;
  position:relative;
  z-index:1;
}
.footer-wrap{
  display:grid;
  gap:30px;
}
.footer-top{
  display:grid;
  grid-template-columns:1.6fr 1fr 1fr 1fr;
  gap:34px;
  padding-bottom:30px;
  border-bottom:1px solid rgba(220,240,240,0.14);
}
.footer-brand-logo{height:32px;width:auto;display:block;}
.footer-brand-copy{
  margin-top:14px;
  max-width:340px;
  color:rgba(220,240,240,0.74);
  font-size:0.94rem;
  line-height:1.75;
}
.footer-col-title{
  color:rgba(220,240,240,0.66);
  font-size:0.68rem;
  letter-spacing:0.16em;
  text-transform:uppercase;
  font-weight:600;
  margin-bottom:14px;
}
.footer-col a{
  display:block;
  color:rgba(240,240,240,0.88);
  text-decoration:none;
  font-size:0.96rem;
  margin-bottom:9px;
}
.footer-col a:hover{
  color:var(--gold);
}
.footer-bottom{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:16px;
  flex-wrap:wrap;
  color:rgba(220,240,240,0.56);
  font-size:0.82rem;
}
.footer-bottom-links{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
}
.footer-bottom-links a{
  color:rgba(220,240,240,0.58);
  text-decoration:none;
}
.footer-bottom-links a:hover{
  color:var(--gold);
}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.hero>div>*{animation:fadeUp 0.65s ease both;}
.hero>div>*:nth-child(2){animation-delay:0.08s;}
.hero>div>*:nth-child(3){animation-delay:0.16s;}
.hero>div>*:nth-child(4){animation-delay:0.24s;}
.hero>div>*:nth-child(5){animation-delay:0.36s;}

@media(max-width:640px){
  .solution-layout,.hero-visual{grid-template-columns:1fr;}
  .hero .container{max-width:960px;}
  .hero-copy{max-width:none;}
  .hero h1{font-size:clamp(2.15rem,12vw,3.9rem);line-height:0.96;letter-spacing:-0.045em;max-width:none;}
  .hero-line,.hero-line-accent{white-space:nowrap;}
  .hero-badge{font-size:0.66rem;letter-spacing:0.1em;padding:6px 14px;}
  .hero-sub{font-size:1rem;line-height:1.65;}
  .hero-actions{width:100%;}
  .hero-actions .btn-primary,.hero-actions .btn-ghost{width:100%;justify-content:center;}
  .faq-question{gap:18px;padding:22px 0;}
  .faq-question-text{font-size:0.97rem;padding-right:0;}
  .faq-toggle{width:46px;height:46px;}
  .faq-toggle::before,.faq-toggle::after{width:14px;}
  .faq-answer-inner{padding:0 0 26px 0;}
  .cta-section{padding:44px 24px;}
  .use-cases{grid-template-columns:1fr 1fr;}
  .footer-top{grid-template-columns:1fr;gap:24px;}
  .footer-brand-copy{max-width:none;}
  .footer-bottom{flex-direction:column;align-items:flex-start;}
  .footer-bottom-links{gap:8px 12px;}
}
