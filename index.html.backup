<script>
const statNumbers = document.querySelectorAll('.hero-stat-num[data-count-to]');
const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

function formatStatValue(element, value) {
  const suffix = element.dataset.countSuffix || '';
  return Math.round(value) + suffix;
}

function animateStat(element) {
  const startValue = Number(element.dataset.countFrom || 0);
  const endValue = Number(element.dataset.countTo || 0);
  const duration = Number(element.dataset.countDuration || 1400);
  const parentCard = element.closest('.hero-stat');

  if (prefersReducedMotion) {
    element.textContent = formatStatValue(element, endValue);
    if (parentCard) parentCard.classList.add('is-active');
    return;
  }

  const startTime = performance.now();

  function frame(now) {
    const elapsed = Math.min((now - startTime) / duration, 1);
    const eased = 1 - Math.pow(1 - elapsed, 3);
    const currentValue = startValue + (endValue - startValue) * eased;

    element.textContent = formatStatValue(element, currentValue);

    if (elapsed < 1) {
      requestAnimationFrame(frame);
      return;
    }

    element.textContent = formatStatValue(element, endValue);
    if (parentCard) parentCard.classList.add('is-active');
  }

  requestAnimationFrame(frame);
}

const heroVisual = document.querySelector('.hero-visual');

if (heroVisual && statNumbers.length) {
  let hasStarted = false;

  const startAnimation = () => {
    if (hasStarted) return;
    hasStarted = true;

    statNumbers.forEach((stat, index) => {
      window.setTimeout(() => animateStat(stat), index * 180);
    });
  };

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        startAnimation();
        observer.disconnect();
      });
    }, { threshold: 0.45 });

    observer.observe(heroVisual);
  } else {
    startAnimation();
  }
}

function setupRevealAnimations(configs) {
  const revealTargets = [];

  configs.forEach(config => {
    document.querySelectorAll(config.selector).forEach((element, index) => {
      if (element.dataset.revealReady === 'true') return;

      element.dataset.revealReady = 'true';
      element.classList.add('reveal');

      if (config.direction === 'left') element.classList.add('reveal-left');
      if (config.direction === 'right') element.classList.add('reveal-right');

      const delay = (config.delay || 0) + index * (config.stagger || 0);
      if (delay) element.style.setProperty('--reveal-delay', delay + 'ms');
      if (config.distance) element.style.setProperty('--reveal-distance', config.distance);

      revealTargets.push(element);
    });
  });

  if (!revealTargets.length) return;

  if (prefersReducedMotion || !('IntersectionObserver' in window)) {
    revealTargets.forEach(element => element.classList.add('is-visible'));
    return;
  }

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('is-visible');
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });

  revealTargets.forEach(element => observer.observe(element));
}

function setupFaqAccordion() {
  const faqItems = Array.from(document.querySelectorAll('.faq-item'));
  if (!faqItems.length) return;

  function setFaqState(item, isOpen) {
    const button = item.querySelector('.faq-question');
    item.classList.toggle('is-open', isOpen);
    if (button) button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  }

  faqItems.forEach(item => {
    setFaqState(item, item.classList.contains('is-open'));

    const button = item.querySelector('.faq-question');
    if (!button) return;

    button.addEventListener('click', () => {
      const willOpen = !item.classList.contains('is-open');

      faqItems.forEach(other => setFaqState(other, false));
      if (willOpen) setFaqState(item, true);
    });
  });
}

setupFaqAccordion();

setupRevealAnimations([
  { selector: '#problem .problem-grid', delay: 60 },
  { selector: '#solution .solution-left', direction: 'left', distance: '28px' },
  { selector: '#solution .solution-callout', direction: 'right', delay: 90, distance: '28px' },
  { selector: '#features .use-cases', delay: 60 },
  { selector: '#faq .faq-intro', delay: 20 },
  { selector: '#faq .faq-list', delay: 40 },
  { selector: '#contact .cta-section', delay: 40 }
]);
</script>

</body>
</html>
